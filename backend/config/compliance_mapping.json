{
  "version": "1.0",
  "framework_names": {
    "nist_800_53": "NIST 800-53",
    "soc2": "SOC 2",
    "pci_dss": "PCI DSS v4.0",
    "hipaa": "HIPAA",
    "cis_aws": "CIS AWS Foundations Benchmark v1.5.0"
  },
  "mappings": {
    "pii": {
      "frameworks": ["NIST 800-53", "SOC 2"],
      "controls": {
        "nist_800_53": ["SI-12", "MP-6", "AC-3"],
        "soc2": ["CC6.1", "CC6.5"]
      },
      "requirements": [
        "Must be encrypted at rest",
        "Must be encrypted in transit",
        "Access must be logged",
        "Must have access controls"
      ]
    },
    "financial": {
      "frameworks": ["PCI DSS", "SOC 2"],
      "controls": {
        "pci_dss": ["3.4", "3.5", "4.1", "10.1"],
        "soc2": ["CC6.1"]
      },
      "requirements": [
        "Must be encrypted (AES-256 or stronger)",
        "Access restricted to need-to-know",
        "All access must be audited"
      ]
    },
    "health": {
      "frameworks": ["HIPAA", "NIST 800-53"],
      "controls": {
        "hipaa": ["164.312(a)(1)", "164.312(e)(1)"],
        "nist_800_53": ["SC-28", "AC-6"]
      },
      "requirements": [
        "PHI must be encrypted at rest and in transit",
        "Access controls with minimum necessary principle",
        "Audit logs retained for 6 years"
      ]
    },
    "credentials": {
      "frameworks": ["CIS AWS", "NIST 800-53", "SOC 2"],
      "controls": {
        "cis_aws": ["1.12", "1.14"],
        "nist_800_53": ["IA-5", "SC-12"],
        "soc2": ["CC6.1"]
      },
      "requirements": [
        "Must use Secrets Manager or KMS",
        "Must have rotation enabled",
        "Must not be in plaintext"
      ]
    },
    "logs": {
      "frameworks": ["CIS AWS", "SOC 2"],
      "controls": {
        "cis_aws": ["3.1", "3.4"],
        "soc2": ["CC7.2"]
      },
      "requirements": [
        "Must be encrypted at rest",
        "Retention period must meet policy"
      ]
    }
  }
}
