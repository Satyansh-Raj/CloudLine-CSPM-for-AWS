# CloudLine Environment Configuration
# Copy to backend/.env and fill in your values

# AWS — required
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=          # your 12-digit AWS account ID

# Authentication — auto-generated on first startup if left empty
API_KEY=                 # leave empty; auto-generated and saved on first run

# RBAC / JWT Auth (Batch 4H)
AUTH_ENABLED=true        # set to false to disable JWT enforcement (dev only)
JWT_SECRET=              # leave empty; auto-generated on first run if unset
ADMIN_BOOTSTRAP_EMAIL=   # e.g. admin@yourcompany.com — creates first Admin on startup
ADMIN_BOOTSTRAP_PASSWORD= # min 12 chars — used once, stored as bcrypt hash

# OPA
OPA_MODE=cli             # cli (local) or http (Docker sidecar)
OPA_BINARY_PATH=opa      # path to opa binary, or rely on PATH
OPA_POLICY_DIR=../policies
OPA_HTTP_URL=http://localhost:9720

# DynamoDB
DYNAMODB_ENDPOINT=       # leave empty for real AWS; http://localhost:9730 for local
DYNAMODB_STATE_TABLE=violation-state
DYNAMODB_AUDIT_TABLE=remediation-audit
DYNAMODB_CONFIG_TABLE=auto-remediation-config

# SNS (optional — leave empty to skip alerts)
SNS_ALERT_TOPIC_ARN=arn:aws:sns:ap-south-1:832843292195:cloudline-alerts:07fc8724-6902-4513-aae5-3173f95a4a71

# Jira Integration (optional — leave empty to disable)
JIRA_URL=                # e.g. https://your-team.atlassian.net
JIRA_EMAIL=              # Jira account email
JIRA_API_TOKEN=          # API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT_KEY=        # project key (e.g. SEC); defaults to SEC

# CORS
CORS_ORIGINS=http://localhost:5173

# App
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
