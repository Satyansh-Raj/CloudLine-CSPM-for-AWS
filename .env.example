# CloudLine Environment Configuration
# Copy this file to .env (in the repo root) and fill in your values.

# ─── AWS Credentials ────────────────────────────────────────────────────────
# Required for boto3 collectors to query your AWS account.
# Leave empty to fall back to IAM role / instance profile / AWS CLI profile.
AWS_ACCESS_KEY_ID=              # e.g. AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=          # e.g. wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ─── AWS Configuration ──────────────────────────────────────────────────────
# AWS_REGION (singular) or AWS_REGIONS (comma-separated multi-region)
AWS_REGION=us-east-1            # primary region
# AWS_REGIONS=us-east-1,eu-west-1,ap-south-1   # uncomment for multi-region
AWS_ACCOUNT_ID=                 # your 12-digit AWS account ID

# ─── RBAC / JWT Auth ────────────────────────────────────────────────────────
AUTH_ENABLED=true               # set to false to disable JWT enforcement (dev only)
JWT_SECRET=                     # leave empty — auto-generated and saved to .env on first run
ADMIN_BOOTSTRAP_EMAIL=          # e.g. admin@yourcompany.com — creates the first Admin on startup
ADMIN_BOOTSTRAP_PASSWORD=       # min 12 chars, e.g. Admin@Example123! — used once, stored as bcrypt hash

# ─── OPA Configuration ──────────────────────────────────────────────────────
# Mode: "cli" for local dev (requires opa binary), "http" for Docker sidecar
OPA_MODE=cli
OPA_BINARY_PATH=opa             # path to opa binary, or just "opa" if it is on PATH
OPA_POLICY_DIR=../policies
OPA_HTTP_URL=http://localhost:9720

# ─── DynamoDB Configuration ─────────────────────────────────────────────────
# Leave DYNAMODB_ENDPOINT empty to use real AWS DynamoDB.
# Set to http://localhost:9730 (or http://dynamodb-local:8000 inside Docker)
# to use the local DynamoDB container bundled with docker-compose.
DYNAMODB_ENDPOINT=http://localhost:9730
DYNAMODB_STATE_TABLE=violation-state
DYNAMODB_TRENDS_TABLE=compliance-trends
DYNAMODB_CORRELATION_TABLE=event-correlation
DYNAMODB_AUDIT_TABLE=cloudline-audit-log
DYNAMODB_CONFIG_TABLE=auto-remediation-config
DYNAMODB_USERS_TABLE=cloudline-users
DYNAMODB_INVENTORY_TABLE=resource-inventory
DYNAMODB_ACCOUNTS_TABLE=target-accounts
DYNAMODB_MACIE_TABLE=macie-findings

# ─── SNS Configuration ──────────────────────────────────────────────────────
# Optional — leave empty to skip alert publishing.
SNS_ALERT_TOPIC_ARN=            # e.g. arn:aws:sns:us-east-1:123456789012:cloudline-alerts

# ─── Jira Integration ───────────────────────────────────────────────────────
# Optional — leave all fields empty to disable Jira ticket creation.
JIRA_URL=                       # e.g. https://your-team.atlassian.net
JIRA_EMAIL=                     # Jira account email
JIRA_API_TOKEN=                 # API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT_KEY=               # project key (e.g. CLOUD)

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── Application Settings ───────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.4.16
LOG_LEVEL=INFO
SCAN_INTERVAL_MINUTES=5
CORRELATION_WINDOW_MINUTES=5
DEFAULT_ROLLBACK_WINDOW_MINUTES=60
